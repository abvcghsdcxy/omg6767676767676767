{
  "luau-lsp.sourcemap.rojoProjectFile": "default.project.json",
  "luau-lsp.sourcemap.enabled": true,
  "luau-lsp.types.robloxSecurityLevel": "RobloxScriptSecurity",
  "luau-lsp.platform.type": "roblox",
  "luau-lsp.diagnostics.strictDatamodelTypes": false,
  "luau-lsp.diagnostics.workspace": true,
  "luau-lsp.fflags.enableNewSolver": true,
  "luau-lsp.sourcemap.autogenerate": true,
  "luau-lsp.sourcemap.includeNonScripts": true,
  "luau-lsp.ignoreGlobs": [
    ".bundle/bundled.luau",
    ".vscode/**",
    ".lune/**",
    "types/**"
  ],
  "luau-lsp.bytecode.vectorCtor": "new",
  "luau-lsp.bytecode.vectorLib": "Vector3",
  "luau-lsp.bytecode.vectorType": "Vector3",
  "stylua.verify": true,
  "[luau]": {
    "editor.defaultFormatter": "JohnnyMorganz.stylua"
  },
  //-------------
  "luau-lsp.types.definitionFiles": {
    "rbxcli": "./types/rbxcli_docs.d.luau"
  },
  "stylua.targetReleaseVersion": "latest",
  "luau-lsp.studioPlugin.enabled": false,
  "editor.formatOnSave": true
}